{
  "expo": {
    "name": "Kashy",
    "slug": "kashy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kashy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.kashy",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kashy usa tu ubicacion para completar automaticamente tu ciudad y mejorar tu experiencia en la app."
      }
    },
    "android": {
      "package": "com.anonymous.kashy",
      "adaptiveIcon": {
        "backgroundColor": "#63E696",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "imageWidth": 280,
          "backgroundColor": "#093923",
          "dark": {
            "backgroundColor": "#041A10"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#63E696",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c4126c67-98bc-4f2c-81dc-4b869624548a"
      }
    }
  }
}
